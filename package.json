{
  "name": "urgencias-hgsv",
  "version": "1.0.0",
  "description": "Sistema de Documentación de Urgencias — Hospital General Salvatierra",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "mx.gob.hgsv.urgencias",
    "productName": "Urgencias HGSV",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "src/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "publisherName": "Hospital General Salvatierra"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
